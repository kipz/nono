# Default: LF for all text files
* text=auto eol=lf

# Force LF line endings for shell scripts (required for WSL2/Linux execution)
*.sh text eol=lf

# Source and doc files — LF everywhere for consistency
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Keep Windows batch files as CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Vendored kernel BTF header for the BPF-LSM program. Generated from
# `bpftool btf dump file /sys/kernel/btf/vmlinux format c`; ~150k lines
# of every kernel struct definition, of which the BPF program references
# a handful (linux_binprm, file, inode, super_block). Marking it
# generated keeps it out of language stats and code-search results, and
# collapses it in PR diffs. See crates/nono/src/bpf/README.md for the
# regeneration command.
crates/nono/src/bpf/vmlinux.h linguist-generated=true
